{
  "id": "homelab-jellyfin-illustrative",
  "description": "Illustrative homelab-backed Jellyfin retry window converted into anonymized combined-log input for parity and service/report comparison.",
  "kind": "homelab",
  "corpus": {
    "id": "homelab-jellyfin-illustrative-v1",
    "path": "benchmark/corpora/homelab/jellyfin-illustrative/access.log",
    "format": "combined",
    "profile": "default"
  },
  "normalization": {
    "id": "canonical-summary-v1",
    "path": "benchmark/normalization/canonical-summary-v1.json"
  },
  "evidence": {
    "publishable": true,
    "representation": "illustrative",
    "capture_window": "2026-03-27T22:35:03-07:00/2026-03-27T22:41:23-07:00",
    "traffic_mix_summary": "Two anonymized Jellyfin live-stream retry paths from a bounded homelab capture window with repeated 404 responses.",
    "source_label": "homelab-media-service",
    "redaction_report_path": "benchmark/corpora/homelab/jellyfin-illustrative/redaction-report.json"
  },
  "baseline": {
    "name": "legacy-python",
    "command": [
      "{{baseline_python}}",
      "{{repo_root}}/benchmark/support/legacy_baseline_adapter.py",
      "--legacy-repo",
      "/root/web-log-parser",
      "--corpus",
      "{{corpus}}",
      "--out",
      "{{output}}"
    ],
    "version_command": [
      "{{baseline_python}}",
      "--version"
    ],
    "required_paths": [
      "/root/web-log-parser",
      "{{repo_root}}/benchmark/support/legacy_baseline_adapter.py"
    ],
    "repo_path": "/root/web-log-parser",
    "controls": {
      "warmup_iterations": 1,
      "measured_iterations": 2,
      "cache_posture": "cold",
      "concurrency": 1,
      "max_procs": 1
    }
  },
  "rewrite": {
    "name": "parsergo-rewrite",
    "command": [
      "{{go_binary}}",
      "run",
      "./cmd/bench",
      "impl",
      "rewrite",
      "--corpus",
      "{{corpus}}",
      "--out",
      "{{output}}",
      "--format",
      "{{format}}",
      "--profile",
      "{{profile}}"
    ],
    "version_command": [
      "{{go_binary}}",
      "version"
    ],
    "working_dir": "{{repo_root}}",
    "required_paths": [
      "{{repo_root}}/cmd/bench/main.go"
    ],
    "repo_path": "{{repo_root}}",
    "controls": {
      "warmup_iterations": 1,
      "measured_iterations": 2,
      "cache_posture": "cold",
      "concurrency": 1,
      "max_procs": 1
    }
  }
}
